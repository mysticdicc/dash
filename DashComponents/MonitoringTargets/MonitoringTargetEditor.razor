@inject IMonitorTargetAPI MonitorTargetService

@if (EditorVisible && null != _monitoringTarget)
{
    <div class="faded_background">
        <div class="ip_editor" @key="_monitoringTarget.GetType()">
            <header>
                <span><strong>
                    @if (_monitoringTarget is IpMonitoringTarget ip)
                    {
                        @IpMonitoringTarget.ConvertToString(ip.Address)
                    }
                    else if (_monitoringTarget is DnsMonitoringTarget dns)
                    {
                        @dns.Address
                    }
                </strong></span>
                <button id="cancelbutton" onclick="@OnClickCancel">
                    <span class="material-icons">cancel</span>
                </button>
            </header>
            <article>
                <table>
                    @if (IsNewTarget || _monitoringTarget is DnsMonitoringTarget)
                    {
                        <tr>
                            <td>
                                <input type="text" @bind="_addressString" @bind:after="@OnAddressStringChanged" placeholder="Address" />
                            </td>
                        </tr>
                    }
                    <tr>
                        <td>
                            <input id="hostnameinput" type="text" @bind="_monitoringTarget.Hostname" placeholder="Hostname" />
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Icmp Monitored
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div>
                                True
                                <input type="radio" value="true" checked="@(_monitoringTarget.IsMonitoredIcmp == true)" @onchange="@((e) => OnIcmpMonitoredChange(e))" />
                            </div>
                            <div>
                                False
                                <input type="radio" value="false" checked="@(_monitoringTarget.IsMonitoredIcmp == false)" @onchange="@((e) => OnIcmpMonitoredChange(e))" />
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            TCP Monitored
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div>
                                True
                                <input type="radio" value="true" checked="@(_monitoringTarget.IsMonitoredTcp == true)" @onchange="@((e) => OnTcpMonitoredChange(e))" />
                            </div>
                            <div>
                                False
                                <input type="radio" value="false" checked="@(_monitoringTarget.IsMonitoredTcp == false)" @onchange="@((e) => OnTcpMonitoredChange(e))" />
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            @if (_monitoringTarget.IsMonitoredTcp)
                            {
                                <input type="text" @bind="_portsMonitoredString" placeholder="Monitored Ports" />
                            }
                            else
                            {
                                <input type="text" @bind="_portsMonitoredString" placeholder="Monitored Ports" readonly="readonly" />
                            }
                        </td>
                    </tr>
                </table>
            </article>
            <footer>
                <button id="savebutton" onclick="@OnClickSave">
                    <span class="material-icons">save</span>
                </button>
            </footer>
        </div>
    </div>
}

@code {
    [Parameter] public required BaseMonitoringTarget MonitoringTarget { get; set; }
    private BaseMonitoringTarget _monitoringTarget = new DnsMonitoringTarget();
    private string _portsMonitoredString = string.Empty;
    private string _addressString = string.Empty;

    [Parameter] public bool IsNewTarget { get; set; } = false;
    [Parameter] public EventCallback<bool> IsNewTargetChanged { get; set; }
    [Parameter] public EventCallback<BaseMonitoringTarget> OnTargetSaved { get; set; }
    [Parameter] public required bool EditorVisible { get; set;}
    [Parameter] public required EventCallback<bool> EditorVisibleChanged { get; set;}

    protected override void OnParametersSet()
    {
        if (_monitoringTarget != MonitoringTarget)
        {
            _monitoringTarget = MonitoringTarget;

            if (_monitoringTarget is DnsMonitoringTarget dns)
            {
                _addressString = dns.Address;
            }
            else if (_monitoringTarget is IpMonitoringTarget ip)
            {
                _addressString = IpMonitoringTarget.ConvertToString(ip.Address);
            }

            if (EditorVisible)
            {
                if (_monitoringTarget.TcpPortsMonitored.Count > 0)
                {
                    _portsMonitoredString = string.Join(",", _monitoringTarget.TcpPortsMonitored);
                }
                else
                {
                    _portsMonitoredString = string.Empty;
                }
            }
        }
    }

    private async Task OnClickCancel()
    {
        _monitoringTarget = new IpMonitoringTarget();
        _portsMonitoredString = string.Empty;
        await EditorVisibleChanged.InvokeAsync(false);
        EditorVisible = false;
        _addressString = string.Empty;
    }

    private void UpdatePortsMonitored()
    {
        if (_monitoringTarget == null) return;

        if (string.IsNullOrWhiteSpace(_portsMonitoredString))
        {
            _monitoringTarget.TcpPortsMonitored = [];
        }
        else
        {
            var ports = _portsMonitoredString
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(p => p.Trim())
                .Where(p => int.TryParse(p, out _))
                .Select(int.Parse)
                .ToList();

            _monitoringTarget.TcpPortsMonitored = ports.Count > 0 ? ports : [];
        }
    }

    private async void OnClickSave()
    {
        if (null != _monitoringTarget)
        {
            UpdatePortsMonitored();

            if (IsNewTarget)
            {
                await OnTargetSaved.InvokeAsync(_monitoringTarget);
            }
            else
            {
                if (_monitoringTarget is DnsMonitoringTarget dns)
                {
                    await MonitorTargetService.UpdateDnsTargetAsync(dns);
                }
                else if (_monitoringTarget is IpMonitoringTarget ip)
                {
                    await MonitorTargetService.UpdateIpTargetAsync(ip);
                }
            }

            await EditorVisibleChanged.InvokeAsync(false);
            _addressString = string.Empty;
        }
    }

    private void OnIcmpMonitoredChange(ChangeEventArgs e)
    {
        if (null != _monitoringTarget)
        {
            var selected = e.Value?.ToString();
            _monitoringTarget.IsMonitoredIcmp = selected == "true";

            if (!_monitoringTarget.IsMonitoredIcmp)
            {
                _monitoringTarget.IsMonitoredTcp = false;
            }
        }
    }

    private void OnTcpMonitoredChange(ChangeEventArgs e)
    {
        if (null != _monitoringTarget)
        {
            var selected = e.Value?.ToString();
            _monitoringTarget.IsMonitoredTcp = selected == "true";

            if (!_monitoringTarget.IsMonitoredIcmp)
            {
                _monitoringTarget.IsMonitoredIcmp = true;
            }
        }
    }

    private void OnAddressStringChanged()
    {
        if (_monitoringTarget is DnsMonitoringTarget dns)
        {
            dns.Address = _addressString;
        }
        else if (_monitoringTarget is IpMonitoringTarget ip)
        {
            try
            {
                ip.Address = IpMonitoringTarget.ConvertToByte(_addressString);
            }
            catch
            {
                
            }
        }
    }
}

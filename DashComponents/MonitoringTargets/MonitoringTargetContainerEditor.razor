@inject IMonitorTargetAPI MonitorTargetService

@if (EditorVisible)
{
    <div class="faded_background">
        <div class="subnet_editor">
            <header>
                <span>
                    <strong>
                        @if (IsNewContainer)
                        {
                            @if (_monitoringTargetContainer is DnsContainer dns)
                            {
                                @dns.DisplayName <strong>- New!</strong>
                            }
                            else if (_monitoringTargetContainer is SubnetContainer subnet)
                            {
                                @IpMonitoringTarget.ConvertToString(subnet.Address) <strong>- New!</strong>
                            }
                        }
                        else
                        {
                            @if (_monitoringTargetContainer is DnsContainer dns)
                            {
                                @dns.DisplayName
                            }
                            else if (_monitoringTargetContainer is SubnetContainer subnet)
                            {
                                @IpMonitoringTarget.ConvertToString(subnet.Address)
                            }
                        }
                    </strong>
                </span>
                <button id="cancelbutton" onclick="@OnClickCancel">
                    <span class="material-icons">cancel</span>
                </button>
            </header>
            <article>
                <table>
                    <tr>
                        <td>
                            Generate Subnet
                        </td>
                    </tr>
                    <tr id="cidr">
                        <td colspan="10">
                            <input id="cidrinput" type="text" @bind="_address" @bind:event="oninput" @onkeydown="OnKeyDownCidrInput" placeholder="192.168.0.1/24" />
                            @if (_monitoringTargetContainer is SubnetContainer)
                            {
                                <button id="generatebutton" type="button" @onclick="OnClickCidrGenerate">
                                    <span class="material-icons">start</span>
                                </button>
                            }
                        </td>
                    </tr>
                    <tr>
                        @if (_monitoringTargetContainer is SubnetContainer)
                        {
                            <td>
                                Start Address
                            </td>
                            <td>
                                End Address
                            </td>
                        }
                    </tr>
                    <tr>
                        @if (_monitoringTargetContainer is SubnetContainer container)
                        {
                            <td>
                                <input type="text" @bind="container.StartAddress" readonly="readonly" />
                            </td>
                            <td>
                                <input type="text" @bind="container.EndAddress" readonly="readonly" />
                            </td>
                        }
                    </tr>
                    <tr>
                        <td colspan="10">
                            <button id="iplist" onclick="@OnClickIpListExpand">
                                <span class="material-icons">list</span>
                                <span><strong>IP List</strong></span>
                            </button>
                        </td>
                    </tr>
                    @if (_monitoringTargetContainer.Children.Count > 0 && _targetListVisible)
                    {
                        <Virtualize Items="_monitoringTargetContainer.Children" Context="target">
                            <ItemContent>
                                <tr id="ip">
                                    <td colspan="10">
                                        <span>
                                            @if (target is DnsMonitoringTarget dnsTarget)
                                            {
                                                @dnsTarget.Address   
                                            }
                                            else if (target is IpMonitoringTarget ipTarget)
                                            {
                                                @IpMonitoringTarget.ConvertToString(ipTarget.Address)
                                            }
                                        </span>
                                        <span>@target.Hostname</span>
                                        <button id="deleteipbutton" onclick="@(() => OnClickDeleteTarget(target))">
                                            <span class="material-icons">delete</span>
                                        </button>
                                    </td>
                                </tr>
                            </ItemContent>
                        </Virtualize>
                    }
                </table>
            </article>
            <footer>
                <button id="savebutton" onclick="@OnClickSave">
                    <span class="material-icons">save</span>
                </button>
            </footer>
        </div>
    </div>
}

@code {
    [Parameter] public required bool EditorVisible { get; set; }
    [Parameter] public required EventCallback<bool> EditorVisibleChanged { get; set; }

    [Parameter] public required bool IsNewContainer { get; set; }
    [Parameter] public required EventCallback<bool> IsNewContainerChanged { get; set; }
    [Parameter] public required EventCallback<BaseMonitoringTargetContainer> ContainerSaved { get; set; }

    [Parameter] public required BaseMonitoringTargetContainer MonitoringTargetContainer { get; set; }
    private BaseMonitoringTargetContainer _monitoringTargetContainer = new DnsContainer("");

    private string _address = string.Empty;
    private bool _targetListVisible = false;

    override protected async Task OnParametersSetAsync()
    {
        if (MonitoringTargetContainer.Id != _monitoringTargetContainer.Id)
        {
            _monitoringTargetContainer = MonitoringTargetContainer;

            if (!IsNewContainer && _monitoringTargetContainer is SubnetContainer subnet)
            {
                try
                {
                    _address = SubnetContainer.GetCidrString(subnet);
                }
                catch { }
            }
            else
            {
                _address = string.Empty;
            }
        }

        await base.OnParametersSetAsync();
    }

    void OnClickCancel()
    {
        EditorVisibleChanged.InvokeAsync(false);
        EditorVisible = false;
    }

    void OnClickCidrGenerate()
    {
        _monitoringTargetContainer = new SubnetContainer(_address);
        _targetListVisible = false;
        StateHasChanged();
    }

    void OnClickIpListExpand()
    {
        _targetListVisible = !_targetListVisible;
    }

    async Task OnClickDeleteTarget(BaseMonitoringTarget target)
    {
        if (target is IpMonitoringTarget ip)
        {
            await MonitorTargetService.DeleteIpTargetAsync(ip);
        }
        else if (target is DnsMonitoringTarget dns)
        {
            await MonitorTargetService.DeleteDnsTargetAsync(dns);
        }

        _monitoringTargetContainer.Children.Remove(target);
        StateHasChanged();
    }

    async void OnClickSave()
    {
        if (IsNewContainer)
        {
            if (_monitoringTargetContainer is DnsContainer dns)
            {
                dns.DisplayName = _address;
                await MonitorTargetService.AddDnsContainerAsync(dns);
            }
            else if (_monitoringTargetContainer is SubnetContainer subnet)
            {
                await MonitorTargetService.AddSubnetContainerAsync(subnet);
            }
        }
        else
        {
            if (_monitoringTargetContainer is DnsContainer dns)
            {
                dns.DisplayName = _address;
                await MonitorTargetService.UpdateDnsContainerAsync(dns);
            }
            else if (_monitoringTargetContainer is SubnetContainer subnet)
            {
                await MonitorTargetService.UpdateSubnetContainerAsync(subnet);
            }
        }

        _address = string.Empty;
        await EditorVisibleChanged.InvokeAsync(false);
        await ContainerSaved.InvokeAsync(_monitoringTargetContainer);
    }

    private async Task OnKeyDownCidrInput(KeyboardEventArgs e)
    {
        if (e.Code == "Enter" || e.Code == "NumpadEnter")
        {
            OnClickCidrGenerate();
        }
    }
}

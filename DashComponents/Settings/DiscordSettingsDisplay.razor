@if (IsVisible)
{
    <div class="settings_card">
        <header>
            <h3>Discord Settings</h3>
        </header>
        <content>
            <table>
                <tr>
                    <td>
                        Discord Token:
                    </td>
                    <td>
                        <input type="text" @bind="@_currentSettings.Token" />
                    </td>
                </tr>
                <tr>
                    <td>
                        Discord Channel ID:
                    </td>
                    <td>
                        <input type="number" @bind="@_currentSettings.ChannelID" />
                    </td>
                </tr>
            </table>
        </content>
    </div>
}

@code {
    [Parameter] required public DiscordSettings CurrentSettings { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    private DiscordSettings _currentSettings = new DiscordSettings();

    protected override void OnParametersSet()
    {
        if (null != CurrentSettings && CurrentSettings != _currentSettings)
        {
            _currentSettings = CurrentSettings;
        }

        base.OnParametersSet();
    }
}

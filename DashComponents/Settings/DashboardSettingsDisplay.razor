@if (IsVisible)
{
    <div class="settings_card">
        <header>
            <h3>Dashboard Settings</h3>
        </header>
        <content>
            <table>
                <tr>
                    <td>
                        Background Image:
                    </td>
                    <td>
                        @if (_currentSettings.BackgroundImageDisplay64 != string.Empty && _currentSettings.BackgroundImageDisplay64 != null)
                        {
                            <div class="background_image_settings">
                                <img src="@_currentSettings.BackgroundImageDisplay64"/>
                                <button id="deleteiconbutton" onclick="@OnClickDeleteBackground">
                                    <span class="material-icons">delete</span>
                                </button>
                            </div>

                        }
                        else
                        {
                            <div class="upload_item_box">
                                <label for="upload_new_pic">
                                    <span class="material-icons" style="margin: auto;">add</span>
                                </label>

                                <InputFile onchange="@(args => OnUploadBackground(args))" id="upload_new_pic" style="width: 0%; height: 0; overflow: hidden;" accept="*.jpg" />
                            </div>
                        }
                    </td>
                </tr>
                <tr>
                    <td>
                        PFX File:
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(_currentSettings.HttpsCertBase64))
                        {
                            <div>@_currentSettings.HttpsCertBase64</div>
                            <button @onclick="@OnClickDeleteCert">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        }
                        else
                        {
                            <div class="upload_item_box">
                                <label for="upload_new_cert">
                                    <span class="material-icons" style="margin: auto;">add</span>
                                </label>

                                <InputFile onchange="@(args => OnUploadPfx(args))" id="upload_new_cert" style="width: 0%; height: 0; overflow: hidden;" accept="*.pfx" />
                            </div>
                        }
                    </td>
                </tr>
                <tr>
                    <td>
                        PFX Password:
                    </td>
                    <td>
                        <input type="text" @bind="@_currentSettings.HttpsCertPassword"/>
                    </td>
                </tr>
            </table>
        </content>
    </div>
}

@code {
    [Parameter] required public DashboardSettings CurrentSettings { get; set; }
    [Parameter] public bool IsVisible { get; set; } = true;
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    private DashboardSettings _currentSettings = new DashboardSettings();

    protected override void OnParametersSet()
    {
        if (null != CurrentSettings && CurrentSettings != _currentSettings)
        {
            _currentSettings = CurrentSettings;
        }
        base.OnParametersSet();
    }

    private async Task<string> FileToBase64Async(InputFileChangeEventArgs eventArgs)
    {
        using var memoryStream = new MemoryStream();
        await eventArgs.File.OpenReadStream(10000000).CopyToAsync(memoryStream);
        var bytes = memoryStream.ToArray();
        var base64 = Convert.ToBase64String(bytes);

        return base64;
    }

    private async Task OnUploadBackground(InputFileChangeEventArgs e)
    {
        _currentSettings.BackgroundImage = await FileToBase64Async(e);
        _currentSettings.BackgroundImageDisplay64 = $"data:{e.File.ContentType};base64,{_currentSettings.BackgroundImage}";
    }

    private async Task OnUploadPfx(InputFileChangeEventArgs e)
    {
        _currentSettings.HttpsCertBase64 = await FileToBase64Async(e);
    }

    private void OnClickDeleteBackground()
    {
        _currentSettings.BackgroundImage = string.Empty;
        _currentSettings.BackgroundImageDisplay64 = string.Empty;
        StateHasChanged();
    }

    private void OnClickDeleteCert()
    {
        _currentSettings.HttpsCertBase64 = string.Empty;
        StateHasChanged();
    }
}

@inject ISettingsAPI SettingsService
@inject IJSRuntime JSRuntime

@page "/settings/home"
@attribute [Authorize]

@using DashComponents.Settings
@using DashLib.Interfaces
@using System.Text.Json

<PageTitle>settings</PageTitle>

<InputFile OnChange="@OnClickUpload" id="upload" style="overflow: hidden; width: 0; height: 0;" accept="*.png" />

<article>
    <header>
        <button onclick="@OnClickSave">
            <span class="material-icons">save</span>
        </button>
        <span>
            <button @onclick="@OnClickUploadButton">
                <span title="Upload settings export" class="material-icons">upload</span>
            </button>
            <button @onclick="@OnClickDownloadButton">
                <span title="Download settings export" class="material-icons">download</span>
            </button>
        </span>
    </header>
    <content>
        <div class=settings_layout>
            <MonitoringSettingsDisplay CurrentSettings="@_currentSettings.MonitoringSettings" OnSettingsChanged="@OnSettingsChanged" />
            <AlertSettingsDisplay CurrentSettings="@_currentSettings.MonitoringSettings.AlertSettings" @bind-IsVisible="@_currentSettings.MonitoringSettings.AlertSettings.Enabled" />
            <SmtpSettingsDisplay CurrentSettings="@_currentSettings.MonitoringSettings.SmtpSettings" @bind-IsVisible="@_currentSettings.MonitoringSettings.SmtpSettings.AlertsEnabled" />
            <DiscordSettingsDisplay CurrentSettings="@_currentSettings.MonitoringSettings.DiscordSettings" @bind-IsVisible="@_currentSettings.MonitoringSettings.DiscordSettings.AlertsEnabled" />
            <TelegramSettingsDisplay CurrentSettings="@_currentSettings.MonitoringSettings.TelegramSettings" @bind-IsVisible="@_currentSettings.MonitoringSettings.TelegramSettings.AlertsEnabled" />
            <LoggingSettingsDisplay CurrentSettings="@_currentSettings.LoggingSettings" />
            <SubnetSettingsDisplay CurrentSettings="@_currentSettings.SubnetSettings" />
            <DashboardSettingsDisplay CurrentSettings="@_currentSettings.DashboardSettings" />
            <OtherSettingsDisplay ResetClicked="@OnClickResetToDefault" />
        </div>
    </content>
</article>

@code {
    private AllSettings _currentSettings = new AllSettings();

    protected override async Task OnInitializedAsync()
    {
        _currentSettings = await SettingsService.GetCurrentSettingsAsync();
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            await InitializeMasonryAsync();
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task InitializeMasonryAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("initMasonry", ".settings_layout", new
            {
                columnWidth = 400,
                itemSelector = ".settings_card",
                transitionDuration = "0s",
                fitWidth = true,
                gutter = 10
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Masonry init failed: {ex.Message}");
        }
    }

    private async Task OnLayoutChanged()
    {
        StateHasChanged();
        await Task.Delay(100);

        try
        {
            await JSRuntime.InvokeVoidAsync("relayoutMasonry", ".settings_layout");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Masonry relayout failed: {ex.Message}");
        }
    }

    private async void OnClickSave()
    {
        if (null != _currentSettings)
        {
            await SettingsService.CreateNewSettingsAsync(_currentSettings);
            await RefreshSettings();
        }
    }

    private async void OnClickDownloadButton()
    {
        if (null != _currentSettings)
        {
            await File.SaveAs(JSRuntime, "settings.json", JsonSerializer.Serialize(_currentSettings, AllSettings.JsonOptions));
        }
    }

    private async void OnClickUpload(InputFileChangeEventArgs eventArgs)
    {
        var str = await File.InputFileToString(eventArgs);
        var items = JsonSerializer.Deserialize<AllSettings>(str, AllSettings.JsonOptions);

        if (null != items)
        {
            await SettingsService.CreateNewSettingsAsync(items);
            await RefreshSettings();
        }
    }

    private async void OnClickUploadButton()
    {
        await JSRuntime.InvokeVoidAsync("clickUpload");
    }

    private async void OnClickResetToDefault()
    {
        var settings = new AllSettings(true);

        await SettingsService.CreateNewSettingsAsync(settings);
        await RefreshSettings();
    }

    private async Task RefreshSettings()
    {
        _currentSettings = await SettingsService.GetCurrentSettingsAsync();
        StateHasChanged();

        await Task.Delay(100);
        await InitializeMasonryAsync();
    }

    private async Task OnSettingsChanged()
    {
        Console.WriteLine("OnSettingsChanged called - triggering layout");
        await InvokeAsync(StateHasChanged);
        await OnLayoutChanged();
    }
}
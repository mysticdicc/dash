@page "/register"
@using DashLib.DTO.Auth
@using web.Client.Auth
@inject AuthApiService AuthApi
@inject NavigationManager Navigation

<h3>Register</h3>

<EditForm Model="model" OnValidSubmit="HandleRegister" FormName="RegisterForm">
    <div class="form-row">
        <label>Username</label>
        <InputText @bind-Value="@model.UserName" />
    </div>

    <div class="form-row">
        <label>Display name</label>
        <InputText @bind-Value="@model.DisplayName" />
    </div>

    <div class="form-row">
        <label>Password</label>
        <InputText @bind-Value="@model.Password" type="password" />
    </div>

    <div style="margin-top:1rem">
        <button type="submit" disabled="@isSubmitting">Register</button>
        <a style="margin-left:1rem" href="/login">Sign in</a>
    </div>
</EditForm>

@if (!string.IsNullOrEmpty(error))
{
    <div class="error">@error</div>
}
@if (success)
{
    <div class="success">Registration successful — redirecting to login...</div>
}

@code {
    private RegisterRequestDto model = new();
    private bool isSubmitting;
    private string? error;
    private bool success;

    private async Task HandleRegister()
    {
        error = null;
        success = false;
        isSubmitting = true;

        try
        {
            var ok = await AuthApi.RegisterAsync(model);
            if (ok)
            {
                success = true;
                // small delay so user sees the message, then navigate
                await Task.Delay(700);
                Navigation.NavigateTo("/login");
            }
            else
            {
                error = "Registration failed. Check server logs or username availability.";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
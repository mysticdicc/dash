@page "/login"
@using DashLib.DTO.Auth
@inject web.Client.Auth.AuthApiService AuthApi
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

<h3>Sign in</h3>

<EditForm Model="@credentials" OnValidSubmit="HandleLogin" FormName="LoginForm">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div>
        <label>Username</label>
        <InputText @bind-Value="credentials.UserName" />
    </div>
    <div>
        <label>Password</label>
        <InputText @bind-Value="credentials.Password" type="password" />
    </div>
    <div style="margin-top:1rem">
        <button type="submit">Sign in</button>
    </div>
</EditForm>

@if (!string.IsNullOrEmpty(Error))
{
    <div class="error">@Error</div>
}

@code {
    private LoginRequestDto credentials { get; set; } = new LoginRequestDto();
    private string? Error;

    private async Task HandleLogin()
    {
        if (null == credentials) return;

        Error = null;
        try
        {
            Console.WriteLine($"{credentials.UserName}, {credentials.Password}");
            var result = await AuthApi.LoginAsync(credentials);
            if (result is null)
            {
                Error = "Login failed. Check credentials.";
                return;
            }
        }
        catch(Exception ex)
        {
            Error = ex.Message;
        }

        //Navigation.NavigateTo("/");
    }
}
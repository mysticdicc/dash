@inject LoggingHubService LoggingHub
@inject ILoggingAPI LoggingApiService
@implements IDisposable

<div class="log_table_wrapper">
    <div>
        <button @onclick="@OnClickClearLogs">
            <span class="material-symbols-outlined" title="Clear Logs">clear_all</span>
        </button>
        <button onclick="@OnClickDeleteLogs">
            <span class="material-symbols-outlined" title="Delete Logs">delete</span>
        </button>
    </div>
    <table class="log_table">
        @if (LoggingHub.Logs.Count > 0)
        {
            <Virtualize Items="@LoggingHub.Logs" Context="log" @key="@LoggingHub.Logs" OverscanCount="50">
                <LogRow Log="log" />
            </Virtualize>
        }
    </table>
</div>

@code {
    protected override async Task OnParametersSetAsync()
    {
        await LoggingHub.LoadInitialLogsAsync();
        LoggingHub.OnLogsUpdated += OnLogsChanged;
        await base.OnParametersSetAsync();
    }

    private async void OnLogsChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void OnClickClearLogs()
    {
        LoggingHub.ClearLogs();
        await InvokeAsync(StateHasChanged);
    }

    private async void OnClickDeleteLogs()
    {
        await LoggingApiService.DeleteAllLogEntriesAsync();
        LoggingHub.ClearLogs();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LoggingHub.OnLogsUpdated -= OnLogsChanged;
    }
}
